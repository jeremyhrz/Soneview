# Configuración de Supabase
# Copia este archivo a .env.local y agrega tus credenciales

VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-clave-anon-supabase

# Instrucciones:
# 1. Ve a https://supabase.com y crea un proyecto
# 2. En la configuración del proyecto, ve a "API"
# 3. Copia la "URL" y la "anon public" key
# 4. Pega los valores en las variables de arriba
# 5. Renombra este archivo a .env.local